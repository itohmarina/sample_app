<h2>タイトル</h2>
<p><%= @list.title %></p>

<h2>本文</h2>
<p><%= @list.body %></p>
<!--URL末尾の数字によって、id毎に1つのレコードが呼び出されている-->

<h2>画像</h2>
<% if @list.image.attached? %>
 <%= image_tag @list.image, size:"300x300" %>
<% else %>
 <%= image_tag 'no_image', size:"300x300" %>
<% end %>

<%= link_to "編集", edit_list_path(@list.id) %>